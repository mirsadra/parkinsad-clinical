{
  "rewrites": [
    { "source": "/launch", "destination": "/public/launch.html" },
    { "source": "/((?!launch\\.html$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
